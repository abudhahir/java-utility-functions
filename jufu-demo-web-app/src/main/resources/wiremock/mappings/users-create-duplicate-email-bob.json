{
  "request": {
    "method": "POST",
    "urlPath": "/users",
    "bodyPatterns": [
      {
        "matchesJsonPath": "$.email",
        "equalToJson": "\"bob@example.com\""
      }
    ]
  },
  "response": {
    "status": 409,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "code": "EMAIL_CONFLICT",
      "message": "Email already registered"
    }
  },
  "priority": 5
}

